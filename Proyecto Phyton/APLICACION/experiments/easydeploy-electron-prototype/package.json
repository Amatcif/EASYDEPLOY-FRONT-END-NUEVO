{
  "name": "easydeploy-electron-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "Isolated Electron + React + Vite visual prototype for a possible future Easy Deploy hybrid UI.",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --host=127.0.0.1 --port=5178",
    "electron:dev": "npm run build && electron .",
    "build": "tsc && vite build",
    "package:windows": "npm run build && electron-builder --config electron-builder.yml --windows --x64"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.4",
    "typescript": "^5.9.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^39.2.3",
    "electron-builder": "^26.0.12"
  }
}
