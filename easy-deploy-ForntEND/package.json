{
  "name": "easy-deploy",
  "private": true,
  "version": "2.2.5-25",
  "easyDeployVersion": "2.2.5.25",
  "main": "main.cjs",
  "description": "Easy Deploy desktop frontend with Python bridge",
  "author": "Easy Deploy",
  "type": "commonjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "electron:dev": "set EASYDEPLOY_VITE_URL=http://localhost:3000&& electron .",
    "pack": "electron-builder --config electron-builder.yml --windows --x64",
    "package:windows": "npm run build && npm run pack",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "start:electron": "electron ."
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "express": "^4.21.2",
    "dotenv": "^17.2.3",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "@types/express": "^4.17.21",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
